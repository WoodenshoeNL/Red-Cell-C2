# automatic-test/config/env.toml.example
#
# Copy this file to env.toml and fill in your values.
# env.toml is gitignored because [server].callback_host is host-specific (it
# must be the dev-box IP routable from the [linux]/[windows] targets in
# targets.toml). The autotest harness copies this template on first run and
# exits if callback_host is still unset.
#
# Teamserver connection and test operator credentials.
# Use a dedicated test operator account, not your personal token.

[server]
url              = "wss://127.0.0.1:40056"
rest_url         = "https://127.0.0.1:40056"
# cert_fingerprint is opt-in: set it to the hex SHA-256 of the teamserver's TLS cert
# to enable pinning. Leave absent (or commented out) to skip pinning in local-dev.
# Derive dynamically: openssl s_client -connect 127.0.0.1:40056 </dev/null 2>/dev/null \
#   | openssl x509 -noout -fingerprint -sha256 | cut -d= -f2 | tr -d ':'
# cert_fingerprint = ""
# IP address this machine presents to agents running on remote targets (scenarios 04, 14).
# Must be routable from [linux]/[windows] hosts in targets.toml.
# Derive with: ip route get <linux-target-ip> | grep -oP 'src \K[0-9.]+'
# Leave absent to let listener creation omit hosts (agents cannot check in from remote targets).
# callback_host = "192.168.213.157"   # set to IP reachable from remote targets

# Teamserver host for scenario 14 resource checks (CPU/RSS). Defaults to the
# hostname from [server].url when omitted. For a remote teamserver, set host
# to that machine's address and provide SSH credentials so the harness can
# run `ps` there; otherwise CPU/RSS assertions are skipped.
[teamserver]
# host = "192.168.1.10"
# ssh_user = "ubuntu"
# ssh_port = 22
# ssh_key = "/home/you/.ssh/id_ed25519"
# cpu_limit_pct = 80.0
# rss_limit_mb = 8192.0
# Optional: path on the machine running test.py to teamserver log file (failure diagnostics).
# If set, this local file is preferred over the CLI `log server-tail` fallback.
# log_file = "/var/log/red-cell/teamserver.log"

[operator]
username = "test-operator"
password = "changeme"
# Static REST API key used by red-cell-cli and the autotest harness.
# This is distinct from the operator password above because the REST API
# does not exchange username/password credentials for tokens at runtime.
api_key  = "changeme-api-key"

[timeouts]
# Primary tunables — single place for harness-wide delays (see lib/config.py).
agent_checkin_secs     = 60
command_output_secs    = 30
listener_startup_secs  = 5
poll_interval_secs     = 2.0
ssh_connect_secs       = 10
scp_transfer_secs      = 60
stress_concurrent_checkin_secs = 30
# Seconds to wait for an agent to disconnect/reconnect during interop tests (scenario 19).
agent_disconnect = 30
# Resilience scenarios (21–23): reconnect after listener restart, kill-date drop-off, working-hours probe.
# resilience_reconnect = 120
# resilience_kill_date = 120
# working_hours_probe = 45
# Seconds to wait for a screenshot loot entry to appear (scenario 08).
screenshot_loot = 30
# Seconds to wait for a download loot entry to appear (scenario 11).
loot_entry = 30
# Hard ceiling on how long any single CLI subprocess may run (wall-clock seconds).
# The per-invocation timeout is derived as min(cfg.timeout + 10, max_cli_subprocess_secs).
# Raise this only if you have long-running CLI commands with explicit --timeout values
# that exceed this ceiling.
max_cli_subprocess_secs = 120

[listeners]
# UDP port used by DNS listener lifecycle tests (scenario 02) and DNS E2E test (scenario 15).
# Must not require root on the test VM (use a port > 1024).
dns_port   = 15353
# C2 domain embedded in DNS payloads (scenario 15).
# Must resolve to the teamserver IP on the target's DNS resolver, or configure
# /etc/hosts on the target with: <teamserver-ip>  c2.test.local
dns_domain = "c2.test.local"
# TCP port used by Linux HTTP listener tests (scenarios 04, 06, 07, 14).
linux_port = 19081
# TCP port used by Windows HTTP listener tests (scenarios 05, 06, 07, 09, 10, 17).
windows_port = 19082
# TCP port for payload-build throwaway listener (scenario 03).
payload_build_port = 19080
# TCP port for protocol compliance probe listener (scenario 13).
protocol_probe_port = 19090
# TCP ports for cross-agent interop listeners (scenario 19).
interop_win_port = 19091
interop_lin_port = 19092
# TCP ports for stress/concurrent-agents listeners (scenario 14).
stress_demon_port = 19093
stress_phantom_port = 19094
# TCP ports for RBAC enforcement tests (scenario 12).
# rbac_admin_port is used by the admin-allowed listener create test.
# rbac_viewer_port is used by the viewer-denied listener create test.
rbac_admin_port  = 19098
rbac_viewer_port = 19099
# Named-pipe suffix for SMB listener tests (scenario 16).
# Not a port number — used as the pipe name base (e.g. "\\.\pipe\redcell-c2-<uid>").
smb_pipe = "redcell-c2"

# ── Kerberos scenario 09 (optional) ─────────────────────────────────────────
# Omit [kerberos] or set enabled = false to skip scenario 09. With enabled = true,
# set domain_realm, account_name, and expected_groups (markers that must appear in
# GROUP INFORMATION from whoami /all). Requires a domain-joined Windows target.
# [kerberos]
# enabled = true
# domain_realm = "CONTOSO.COM"
# account_name = "testuser"
# expected_groups = ["Domain Users"]
# expected_impersonation_level = "Identification"

[agents]
# Agent variants enabled for E2E payload-build tests (scenarios 04, 05, 06, 07, 08, 14, 16, 17, 20).
# Payloads for agents NOT in this list are skipped without error.
# Payloads for agents that ARE in this list but fail to build cause the scenario to fail,
# so regressions in payload generation are caught immediately.
#
# Agent matrix:
#   demon    — Windows PE (scenarios 05, 06, 07, 08, 14)
#   archon   — Windows PE, C/ASM fork of Demon + 9 enhancements, ECDH transport (scenarios 05, 06, 07, 08, 17)
#   phantom  — Linux ELF (scenarios 04, 06, 07, 08, 14)
#   specter  — Windows PE, Rust + ECDH transport (scenarios 05, 06, 07, 08, 16, 20)
available = ["demon", "archon", "phantom", "specter"]

# Optional: analyst-role API key for RBAC enforcement tests (scenario 01, 12).
# Leave the api_key field empty ("") to skip the viewer-role tests.
# The teamserver profile must have a matching Api { Key ... { Role = "analyst" } } entry.
[analyst_operator]
username = "test-analyst"
api_key  = "changeme-analyst-key"
