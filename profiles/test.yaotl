Teamserver {
    Host = "127.0.0.1"
    Port = 40056

    Build {
        Compiler64 = "data/x86_64-w64-mingw32-cross/bin/x86_64-w64-mingw32-gcc"
        Compiler86 = "data/i686-w64-mingw32-cross/bin/i686-w64-mingw32-gcc"
        Nasm = "/usr/bin/nasm"
    }
}

Operators {
    user "test-operator" {
        Password = "changeme"
    }

    user "test-analyst" {
        Password = "changeme-analyst"
    }
}

Api {
    RateLimitPerMinute = 120

    key "test-operator" {
        Value = "changeme-api-key"
    }

    key "test-analyst" {
        Value = "changeme-analyst-key"
        Role  = "Analyst"
    }
}

Listeners {
    Http {
        Name         = "default"
        Hosts        = ["127.0.0.1"]
        HostBind     = "0.0.0.0"
        HostRotation = "round-robin"
        PortBind     = 19100
        PortConn     = 19100
        Secure       = false
    }
}

Demon {
    Sleep = 1
    Jitter = 0

    TrustXForwardedFor = false

    # The frozen Demon agent does not negotiate INIT_EXT_MONOTONIC_CTR,
    # so it falls into legacy CTR mode.  Without this flag the teamserver
    # silently rejects every Demon DEMON_INIT.
    AllowLegacyCtr = true

    Injection {
        Spawn64 = "C:\\Windows\\System32\\notepad.exe"
        Spawn32 = "C:\\Windows\\SysWOW64\\notepad.exe"
    }
}
