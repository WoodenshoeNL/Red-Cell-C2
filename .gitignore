# Generated by Cargo
# Compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Dolt database files (added by bd init)
.dolt/
*.db

# GitHub Actions workflows — restored for CI
# .github/ is tracked

# Runtime log files generated by loop scripts
logs/

# Per-machine node identifier — create once with: echo "my-machine-name" > .node-id
.node-id

# br/beads history snapshots — ephemeral, not needed in version control
.beads/.br_history/

# Runtime-generated TLS certificates and SQLite databases (teamserver creates these)
profiles/*.sqlite
profiles/*.sqlite-wal
profiles/*.sqlite-shm
profiles/*.sqlite.key
profiles/*.tls.crt
profiles/*.tls.key

# Claude Code worktrees (ephemeral, machine-local)
.claude/worktrees/

# Temporary files and runtime artifacts
.tmp/
Running
target-codex-x86m/
target-pkvbc/
target-clippy-*/
target-phantom-*/
data/

# Automated test harness — credentials and host-specific config (never commit)
automatic-test/config/targets.toml
automatic-test/config/env.toml
automatic-test/config-autotest/targets.toml
automatic-test/config-autotest/env.toml

# Python bytecode artifacts (autotest harness)
automatic-test/**/__pycache__/
automatic-test/**/*.pyc
