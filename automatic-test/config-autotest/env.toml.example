# automatic-test/config-autotest/env.toml.example
#
# Dedicated harness config for `--loop autotest` mode. Pairs with
# profiles/autotest.yaotl (port 40156, default listener 19200).
#
# Copy this file to env.toml in the same directory and fill in callback_host.
# env.toml is gitignored because [server].callback_host is host-specific
# (it must be the dev-box IP routable from the [linux]/[windows] targets in
# targets.toml).
#
# targets.toml is shared with the regular harness config — symlink it:
#     cd automatic-test/config-autotest
#     ln -s ../config/targets.toml targets.toml
#
# The two test machines, key paths, and SSH ports do not differ between
# normal-mode and autotest-mode runs.

[server]
url              = "wss://127.0.0.1:40156"
rest_url         = "https://127.0.0.1:40156"
# cert_fingerprint is opt-in. Derive dynamically:
#   openssl s_client -connect 127.0.0.1:40156 </dev/null 2>/dev/null \
#     | openssl x509 -noout -fingerprint -sha256 | cut -d= -f2 | tr -d ':'
# cert_fingerprint = ""
# IP address this dev-box presents to agents on the test VMs.
# Must be routable from [linux]/[windows] hosts in targets.toml.
# Derive with: ip route get <linux-target-ip> | grep -oP 'src \K[0-9.]+'
# callback_host = "192.168.x.x"

# Teamserver host for scenario 14 resource checks (CPU/RSS).  Defaults to the
# hostname from [server].url when omitted.  See ../config/env.toml.example for
# the SSH-fields needed for a remote teamserver.
[teamserver]
# log_file = "logs/teamserver.log"   # optional — relative to repo root

[operator]
username = "test-operator"
password = "changeme"
# Static REST API key used by red-cell-cli and the autotest harness.
api_key  = "changeme-api-key"

[timeouts]
agent_checkin_secs     = 60
command_output_secs    = 30
listener_startup_secs  = 5
poll_interval_secs     = 2.0
ssh_connect_secs       = 10
scp_transfer_secs      = 60
stress_concurrent_checkin_secs = 45
agent_disconnect       = 30
screenshot_loot        = 30
loot_entry             = 30
max_cli_subprocess_secs = 120

[listeners]
# Autotest listener ports use a distinct range (191xx) so they never collide
# with listeners left running by the test.yaotl teamserver (which uses 190xx).
# API-port isolation (40056 vs 40156) only separates the control planes; the
# OS-level listener bind ports must also be unique.
dns_port            = 15354
dns_domain          = "c2.test.local"
linux_port          = 19181
windows_port        = 19182
payload_build_port  = 19180
protocol_probe_port = 19190
interop_win_port    = 19191
interop_lin_port    = 19192
stress_demon_port   = 19193
stress_phantom_port = 19194
rbac_admin_port     = 19198
rbac_viewer_port    = 19199
smb_pipe            = "redcell-c2"

# ── Kerberos scenario 09 (optional) ─────────────────────────────────────────
# Omit [kerberos] or set enabled = false to skip scenario 09.
# [kerberos]
# enabled = true
# domain_realm = "CONTOSO.COM"
# account_name = "testuser"
# expected_groups = ["Domain Users"]
# expected_impersonation_level = "Identification"

[agents]
available = ["demon", "archon", "phantom", "specter"]

[analyst_operator]
username = "test-analyst"
api_key  = "changeme-analyst-key"
